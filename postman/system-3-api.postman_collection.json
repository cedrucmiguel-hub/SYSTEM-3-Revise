{
  "info": {
    "_postman_id": "56fd4414-e21d-44e1-9e43-system3api",
    "name": "System 3 Loyalty API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "00 Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "01 Points Service",
      "item": [
        {
          "name": "Award Points - No Body Params",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Idempotency-Key",
                "value": "{{transactionRef}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/points/award?memberIdentifier={{memberId}}&fallbackEmail={{memberEmail}}&points=625&transactionType=PURCHASE&transactionRef={{transactionRef}}&reason=POS%20purchase%20test&amountSpent=500&productCode=SKU-001&productCategory=Beverage",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "points",
                "award"
              ],
              "query": [
                {
                  "key": "memberIdentifier",
                  "value": "{{memberId}}"
                },
                {
                  "key": "fallbackEmail",
                  "value": "{{memberEmail}}"
                },
                {
                  "key": "points",
                  "value": "625"
                },
                {
                  "key": "transactionType",
                  "value": "PURCHASE"
                },
                {
                  "key": "transactionRef",
                  "value": "{{transactionRef}}"
                },
                {
                  "key": "reason",
                  "value": "POS purchase test"
                },
                {
                  "key": "amountSpent",
                  "value": "500"
                },
                {
                  "key": "productCode",
                  "value": "SKU-001"
                },
                {
                  "key": "productCategory",
                  "value": "Beverage"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "pm.environment.set(\"transactionRef\", `POS-${stamp}`);"
                ]
              }
            }
          ]
        },
        {
          "name": "Redeem Points",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberIdentifier\": \"{{memberId}}\",\n  \"fallbackEmail\": \"{{memberEmail}}\",\n  \"points\": 100,\n  \"reason\": \"Reward redemption test\",\n  \"transactionType\": \"REDEEM\",\n  \"rewardCatalogId\": \"REWARD-001\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/points/redeem"
          }
        },
        {
          "name": "Transaction Completed Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"eventId\": \"{{eventId}}\",\n  \"eventType\": \"transaction.completed\",\n  \"transactionReference\": \"{{transactionRef}}-EVENT\",\n  \"memberIdentifier\": \"{{memberId}}\",\n  \"fallbackEmail\": \"{{memberEmail}}\",\n  \"amountSpent\": 500,\n  \"reason\": \"POS transaction completed test\",\n  \"productCode\": \"SKU-001\",\n  \"productCategory\": \"Beverage\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/events/transaction-completed"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "pm.environment.set(\"transactionRef\", `POS-${stamp}`);",
                  "pm.environment.set(\"eventId\", `EVT-${stamp}`);"
                ]
              }
            }
          ]
        }
      ]
    },
