    {
      "name": "03 Campaign and Segments",
      "item": [
        {
          "name": "Create Campaign",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"{{campaignId}}\",\n  \"campaignCode\": \"{{campaignCode}}\",\n  \"campaignName\": \"Postman Bonus Campaign\",\n  \"description\": \"Campaign created from Postman.\",\n  \"campaignType\": \"bonus_points\",\n  \"status\": \"draft\",\n  \"multiplier\": 1,\n  \"minimumPurchaseAmount\": 300,\n  \"bonusPoints\": 100,\n  \"productScope\": [\"Beverage\"],\n  \"eligibleTiers\": [\"Bronze\", \"Silver\", \"Gold\"],\n  \"startsAt\": \"2026-04-20T00:00:00.000Z\",\n  \"endsAt\": \"2026-12-31T23:59:59.000Z\",\n  \"budgetLimit\": 10000,\n  \"pushNotificationEnabled\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/campaigns"
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const stamp = Date.now();",
                  "pm.environment.set(\"campaignId\", `CAMP-${stamp}`);",
                  "pm.environment.set(\"campaignCode\", `POSTMAN-CAMP-${stamp}`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json.campaignId || json.campaign?.id;",
                  "if (id) pm.environment.set(\"campaignId\", id);",
                  "if (json.campaign?.campaignCode) pm.environment.set(\"campaignCode\", json.campaign.campaignCode);",
                  "pm.test(\"campaign id was produced\", function () { pm.expect(id).to.be.a(\"string\").and.not.include(\"{{\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Publish Campaign",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"queueNotifications\": false\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/campaigns/{{campaignId}}/publish"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json.campaignId || json.campaign?.id;",
                  "if (id) pm.environment.set(\"campaignId\", id);",
                  "pm.test(\"campaign was published\", function () { pm.expect(json.campaign?.status).to.eql(\"active\"); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Campaign",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaigns/{{campaignId}}"
          }
        },
        {
          "name": "Get Campaign Budget Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/campaigns/{{campaignId}}/budget-status"
          }
        },
        {
          "name": "Create Segment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman High Value\",\n  \"description\": \"Postman-created segment.\",\n  \"logicMode\": \"AND\",\n  \"conditions\": [\n    {\n      \"id\": \"cond-tier\",\n      \"field\": \"Tier\",\n      \"operator\": \"is\",\n      \"value\": \"Gold\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/segments"
          }
        },
        {
          "name": "Preview Segment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"logicMode\": \"AND\",\n  \"conditions\": [\n    {\n      \"id\": \"cond-points\",\n      \"field\": \"Points Balance\",\n      \"operator\": \"is above\",\n      \"value\": \"100\"\n    }\n  ]\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/segments/preview"
          }
        }
      ]
    },
