FROM node:20-alpine AS deps
WORKDIR /app/src/frontend
COPY src/frontend/package*.json ./
RUN npm install

FROM node:20-alpine AS builder
WORKDIR /app
COPY --from=deps /app/src/frontend/node_modules ./src/frontend/node_modules
COPY . .
WORKDIR /app/src/frontend
RUN npm run build

FROM node:20-alpine AS runner
WORKDIR /app/src/frontend
ENV NODE_ENV=production
ENV PORT=3000
COPY --from=builder /app/src/frontend/.next ./.next
COPY --from=builder /app/src/frontend/package*.json ./
COPY --from=builder /app/src/frontend/node_modules ./node_modules
COPY --from=builder /app/src/frontend/next.config.ts ./next.config.ts
CMD ["npm", "run", "start"]
