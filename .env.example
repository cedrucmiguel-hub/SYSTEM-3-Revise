
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key
NEXT_PUBLIC_ENABLE_DEMO_AUTH=true
NEXT_PUBLIC_FORCE_CUSTOMER_DEMO_AUTH=false
USE_LOCAL_LOYALTY_API=true
POINTS_SERVICE_TIMEOUT_MS=250

# Server-only secret. Do not expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
POINTS_ENGINE_URL=http://127.0.0.1:4001
NEXT_PUBLIC_POINTS_ENGINE_URL=http://127.0.0.1:4001
CAMPAIGN_SERVICE_URL=http://127.0.0.1:4002
NEXT_PUBLIC_CAMPAIGN_SERVICE_URL=http://127.0.0.1:4002
GATEWAY_URL=http://127.0.0.1:4000
NEXT_PUBLIC_GATEWAY_URL=http://127.0.0.1:4000
